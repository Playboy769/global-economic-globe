SQLITE_DB_PATH=articles.db

# 語意搜尋 / 相關文章 開關。預設關閉，因為需要 PyTorch + sentence-transformers，
# 而 Windows Smart App Control 會擋掉這些原生 DLL。
ENABLE_SEMANTIC=false

# AI 功能（自動摘要、自動標籤、翻譯）開關，預設關閉。
# 改成 true 才會啟用，並且需要填入下面的 API key。
ENABLE_AI=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384
